{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Photo Led Lesson Fixture",
  "type": "object",
  "required": ["fixture_id", "about", "title", "template_lane", "assets", "sources", "slides"],
  "properties": {
    "fixture_id": { "type": "string" },
    "about": { "type": "string" },
    "title": { "type": "string" },
    "template_lane": { "const": "photo_led_lesson_deck_v1" },
    "year_level": { "type": "string" },
    "source_grounding_status": { "type": "string" },
    "classroom_review_status": { "type": "string" },
    "assets": { "type": "object" },
    "sources": { "type": "array" },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "component", "title"]
      }
    }
  }
}
